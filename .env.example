# --- MongoDB ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true
MONGODB_DB=chapee

# --- アプリ認証（JWT 署名用。本番では必ず長いランダム文字列に変更）---
AUTH_SECRET=

# --- Shopee Open Platform（Partner API）---
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
# OAuth コールバック後のリダイレクト先（Shopee コンソールの Redirect URL と完全一致）
SHOPEE_REDIRECT_URL=https://your-domain.example.com/api/shopee/callback

# 任意: 複数パートナー国の JSON（1行。未設定時は SHOPEE_PARTNER_ID のみを使用）
# SHOPEE_PARTNERS_JSON=[{"partner_id":0,"partner_key":"","label":"","country":"SG"}]

# 任意: Partner API のホストを上書き（通常は未設定で OK）
# SHOPEE_PARTNER_API_HOST=https://partner.shopeemobile.com
# 任意: sandbox / test-stable 等
# SHOPEE_PARTNER_API_ENV=

# --- Cron 保護（GET /api/cron/* および一部管理 API）---
CRON_SECRET=

# --- 翻訳（DB に未保存の場合のフォールバック。設定画面で優先）---
# DEEPL_API_KEY=
# DEEPL_API_URL=https://api-free.deepl.com
# GOOGLE_TRANSLATE_API_KEY=

# --- Node ---
# NODE_ENV=production
